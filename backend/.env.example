# Server
PORT=8080
ENV=development                              # development | production

# Database — Supabase
# Pooler connection (Session mode, IPv4-compatible, supports advisory locks)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Used by `go test ./...` for service-layer integration tests.
# For now, point this at the same database as DATABASE_URL.
TEST_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Auth
JWT_SECRET=change-me-in-production          # min 32 chars, random
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h                      # 7 days

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
